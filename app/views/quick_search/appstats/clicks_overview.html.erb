<% content_for :head do %>
  <script>
    window.QuickSearchRoutes = {
      data_module_clicks: '<%= QuickSearch::Engine.routes.url_helpers.data_module_clicks_path %>',
      data_result_clicks: '<%= QuickSearch::Engine.routes.url_helpers.data_result_clicks_path %>',
      data_module_details: '<%= QuickSearch::Engine.routes.url_helpers.data_module_details_path %>'
    };
  </script>
  <script src="<%= asset_path('appstats/appstats.js') %>" data-turbo-track="reload"></script>
  <script src="<%= asset_path('appstats/appstats_clicks_overview.js') %>" data-turbo-track="reload"></script>
<% end %>
<% title("#{@page_title} | ") %>
<%= render partial: 'datatables' %>
<div class="row">
    <%= render partial: 'menu' %>
    <div class="medium-8 columns">
        <%= render partial: 'graph_clicks_overview' %>
    </div>
    <%= render partial: "date_range" %>
</div>
